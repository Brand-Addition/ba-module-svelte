<?php
/** @var \BA\Svelte\Block\Assets $block */
/** @var \Magento\Framework\Escaper $escaper */
/** @var \Magento\Framework\View\Helper\SecureHtmlRenderer $secureRenderer */
$storeCode = $block->getStoreCode();
$svelteTranslationsJson = $block->getSvelteTranslationsJson();
$entryStyleUrl = $block->getViewFileUrl("js/dist/svelte-app.css");
$entryScriptUrl = $block->getViewFileUrl("js/dist/svelte-app.js");
$currentLocale = $block->getCurrentLocale();
$currentCurrency = $block->getCurrentCurrency();

$assetBootstrapScript = <<<JS
(function () {
    var styleUrl = '{$escaper->escapeJs($entryStyleUrl)}';
    var scriptUrl = '{$escaper->escapeJs($entryScriptUrl)}';
    var storefrontStoreCode = '{$escaper->escapeJs($storeCode)}';
    var svelteTranslations = {$svelteTranslationsJson};
    var currentLocale = '{$escaper->escapeJs($currentLocale)}';
    var currentCurrency = '{$escaper->escapeJs($currentCurrency)}';

    if (typeof storefrontStoreCode === 'string' && storefrontStoreCode !== '') {
        window.__baStoreCode = storefrontStoreCode;
    }

    window.__baSvelteTranslations = Object.assign(
        window.__baSvelteTranslations || Object.create(null),
        svelteTranslations
    );

    window.baTranslate = window.baTranslate || function (text) {
        if (typeof text !== 'string' || text === '') {
            return text;
        }

        return window.__baSvelteTranslations[text] || text;
    };

    if (!document.querySelector('link[data-ba-svelte-bundle="true"][href="' + styleUrl + '"]')) {
        var style = document.createElement('link');
        style.rel = 'stylesheet';
        style.href = styleUrl;
        style.setAttribute('data-ba-svelte-bundle', 'true');
        document.head.appendChild(style);
    }

    if (!window.__baSvelteBundleRequested) {
        var script = document.createElement('script');
        script.type = 'module';
        script.src = scriptUrl;
        window.__baSvelteBundleRequested = true;
        document.head.appendChild(script);
    }

    window.__baCurrentLocale = currentLocale;
    window.__baCurrentCurrency = currentCurrency;
}());
JS;
?>
<?= /* @noEscape */ $secureRenderer->renderTag(
        "script",
        [],
        $assetBootstrapScript,
        false,
    ) ?>
