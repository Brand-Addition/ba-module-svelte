<?php
/** @var \BA\Svelte\Block\Assets $block */
/** @var \Magento\Framework\Escaper $escaper */
/** @var \Magento\Framework\View\Helper\SecureHtmlRenderer $secureRenderer */
$storeCode = $block->getStoreCode();
$entryStyleUrl = $block->getViewFileUrl('js/dist/svelte-app.css');
$entryScriptUrl = $block->getViewFileUrl('js/dist/svelte-app.js');
$assetBootstrapScript = <<<JS
(function () {
    var styleUrl = '{$escaper->escapeJs($entryStyleUrl)}';
    var scriptUrl = '{$escaper->escapeJs($entryScriptUrl)}';
    var storefrontStoreCode = '{$escaper->escapeJs($storeCode)}';
    var hasOwn = Object.prototype.hasOwnProperty;

    if (typeof storefrontStoreCode === 'string' && storefrontStoreCode !== '') {
        window.__baStoreCode = storefrontStoreCode;
    }

    window.mageTranslate = window.mageTranslate || function (text) {
        if (typeof text !== 'string' || text === '') {
            return text;
        }

        if (
            window.__baMagentoTranslationDictionary &&
            hasOwn.call(window.__baMagentoTranslationDictionary, text)
        ) {
            return window.__baMagentoTranslationDictionary[text];
        }

        if (window.mage && typeof window.mage.__ === 'function') {
            return window.mage.__(text);
        }

        return text;
    };

    if (!window.__baMagentoTranslationDictionaryRequested && typeof window.require === 'function') {
        window.__baMagentoTranslationDictionaryRequested = true;
        window.require(['mageTranslationDictionary'], function (dictionary) {
            if (dictionary && typeof dictionary === 'object') {
                window.__baMagentoTranslationDictionary = dictionary;
            }
        });
    }

    if (!document.querySelector('link[data-ba-svelte-bundle="true"][href="' + styleUrl + '"]')) {
        var style = document.createElement('link');
        style.rel = 'stylesheet';
        style.href = styleUrl;
        style.setAttribute('data-ba-svelte-bundle', 'true');
        document.head.appendChild(style);
    }

    if (!window.__baSvelteBundleRequested) {
        var script = document.createElement('script');
        script.type = 'module';
        script.src = scriptUrl;
        window.__baSvelteBundleRequested = true;
        document.head.appendChild(script);
    }
}());
JS;
?>
<?= /* @noEscape */ $secureRenderer->renderTag('script', [], $assetBootstrapScript, false) ?>
